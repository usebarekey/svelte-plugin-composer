{
  "name": "svelte-plugin-composer",
  "version": "0.1.0",
  "description": "Compose SvelteKit plugin stacks with config merging and Vite ordering policy.",
  "license": "BSD-3-Clause",
  "type": "module",
  "engines": {
    "node": "^22.12.0 || >=24.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandersonstabo/svelte-plugin-composer.git"
  },
  "files": [
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/mod.ts",
      "default": "./src/mod.js"
    },
    "./vite": {
      "types": "./src/vite.ts",
      "default": "./src/vite.js"
    }
  },
  "scripts": {
    "check": "deno task check",
    "fmt": "deno task fmt",
    "lint": "deno task lint",
    "test": "deno task test"
  },
  "peerDependencies": {
    "@sveltejs/kit": "^2.62.0 || ^3.0.0-next.0",
    "svelte": "^5.0.0",
    "vite": "^7.0.0 || ^8.0.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.0",
    "@sveltejs/kit": "^2.62.0",
    "svelte": "^5.0.0",
    "vite": "^8.0.0"
  }
}
